---
import { getCollection } from "astro:content";
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";

const CATEGORIES = ["游记", "题解", "文化课", "闲话", "笔记"] as const;
const posts = await getCollection("blog");

const categoryCounts = CATEGORIES.map(cat => ({
  name: cat,
  count: posts.filter(p => !p.data.draft && p.data.category === cat).length,
}));
---

<Layout title={`分类 | ${SITE.title}`}>
  <Header />
  <Main pageTitle="分类" pageDesc="按分类浏览所有文章">
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      {categoryCounts.map(({ name, count }) => (
        <a
          href={`/category/${name}/`}
          class="group flex items-center justify-between rounded-xl border border-border p-5 transition-all hover:border-accent hover:shadow-sm"
        >
          <span class="text-lg font-medium group-hover:text-accent">{name}</span>
          <span
            class="inline-flex h-7 min-w-7 items-center justify-center rounded-full text-sm font-bold"
            style="background-color: #2563eb; color: white;"
          >
            {count}
          </span>
        </a>
      ))}
    </div>
  </Main>
  <Footer />
</Layout>
